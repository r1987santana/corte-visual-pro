{
  "name": "rd-wood-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "tsc --noEmit",
    "audit:api-security": "node scripts/api-security-audit.mjs",
    "audit:pending": "node scripts/pending-change-groups.mjs",
    "audit:modules": "node scripts/module-size-audit.mjs",
    "audit:modules:strict": "node scripts/module-size-audit.mjs --strict",
    "audit:stability": "npm run lint && npm run audit:api-security && npm run audit:modules && npm run test:materials",
    "fix:mojibake-critical": "node scripts/fix-mojibake-critical.mjs --write",
    "test:materials": "node --no-warnings scripts/centro-tv-material-regression.mjs",
    "pilot:check": "node scripts/pilot-check.mjs",
    "ops:reset-operational-data": "node scripts/reset-operational-data-keep-inventory.mjs",
    "warmup": "node scripts/warmup-routes.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@vladmandic/face-api": "^1.7.15",
    "exceljs": "^4.4.0",
    "imagetracerjs": "^1.2.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.16.0",
    "next": "^16.2.7",
    "opentype.js": "^2.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.8.1",
    "uuid": "^14.0.0"
  },
  "overrides": {
    "postcss": "^8.5.14",
    "exceljs": {
      "uuid": "^11.1.1"
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
