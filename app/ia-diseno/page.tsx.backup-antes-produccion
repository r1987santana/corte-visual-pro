  notes?: string | null;
  presupuesto?: number | null;
  status?: string | null;
  created_at?: string | null;
  render_image_url?: string | null;
};

type DesignModule = {
  id: string;
  name: string;
  type: string;
  quantity: number;
  width_mm: number;
  depth_mm: number;
  height_mm: number;
